{
  "name": "llm-testrunner-components",
  "version": "1.3.1",
  "description": "A Stencil web component library for LLM test runner functionality",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/llm-testrunner-components/llm-testrunner-components.esm.js",
  "exports": {
    "./react": {
      "import": "./dist/react/components.js",
      "require": "./dist/react/components.js",
      "types": "./dist/react/components.d.ts"
    },
    "./react/types": {
      "types": "./dist/types/index.d.ts"
    },
    "./schema": {
      "import": "./dist/collection/schemas/expected-outcome.js",
      "types": "./dist/types/schemas/expected-outcome.d.ts"
    },
    "././dist/components/*": {
      "import": "./dist/components/*",
      "require": "./dist/components/*",
      "types": "./dist/components/*"
    },
    "./loader": {
      "import": "./loader/index.js",
      "require": "./loader/index.cjs",
      "types": "./loader/index.d.ts"
    },
    "./dist/*": {
      "import": "./dist/*",
      "types": "./dist/*"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FluxonApps/llm-testrunner-lib.git"
  },
  "bugs": {
    "url": "https://github.com/FluxonApps/llm-testrunner-lib/issues"
  },
  "homepage": "https://github.com/FluxonApps/llm-testrunner-lib#readme",
  "author": "Fluxon Apps LLC",
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "start": "stencil build --dev --watch --serve",
    "test": "stencil test --spec --e2e --passWithNoTests",
    "test.watch": "stencil test --spec --e2e --watchAll",
    "generate": "stencil generate",
    "build": "stencil build",
    "watch": "concurrently -n \"Stencil Build,React Wrapper\" -c \"cyan,magenta\" \"stencil build --watch\" \"wait-on generated/react/components.ts && npm run watch:react-wrapper\"",
    "build:react": "tsc --project tsconfig.react.json",
    "watch:react-wrapper": "nodemon --watch generated/react --ext ts,tsx --exec \"npm run build:react\"",
    "build:all": "npm run build && npm run build:react",
    "build-publish": "npm run build:all && npm run just-publish",
    "just-publish": "npm publish --access=public",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "license-check": "licensee"
  },
  "dependencies": {
    "@google/genai": "^1.40.0",
    "@stencil/react-output-target": "^1.2.0",
    "@types/uuid": "^10.0.0",
    "@xenova/transformers": "^2.17.2",
    "bleu-score": "^1.0.4",
    "js-rouge": "^3.0.0",
    "uuid": "^10.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@rollup/plugin-replace": "^6.0.2",
    "@stencil/core": "^4.27.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "licensee": "^12.0.1",
    "nodemon": "^3.1.11",
    "prettier": "^3.6.2",
    "puppeteer": "^24.3.0",
    "wait-on": "^9.0.3"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "license": "MIT",
  "overrides": {
    "protobufjs": "^7.5.5"
  },
  "keywords": [
    "web-components",
    "stencil",
    "react",
    "typescript"
  ]
}
